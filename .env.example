# Supabase Configuration (Modern Keys - https://supabase.com/docs/guides/api/api-keys)
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx  # Modern key (replaces anon)

# Optional: Only needed for admin operations (seed scripts, bypass RLS)
SUPABASE_SECRET_KEY=sb_secret_xxx  # Modern key (replaces service_role)

# Database
DATABASE_URL="postgresql://postgres:password@localhost:54322/postgres?schema=public"

# Application
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Encryption (Generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your-32-byte-base64-encoded-key
