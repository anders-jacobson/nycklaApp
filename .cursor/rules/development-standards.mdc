## 📊 Database Patterns (Our Schema)

### Current Models

```typescript
// Core entities in our Prisma schema
User {
  id: string (UUID)
  email: string (unique)
  cooperative: string (required during signup)
  // Relations: keyTypes[], borrowers[], issueRecords[]
}

KeyType {
  label: string (2 chars, e.g., "A1")
  function: string (description, e.g., "Main entrance")
  accessArea?: string
  // Relations: keyCopies[]
}

KeyCopy {
  copyNumber: number (sequential: 1, 2, 3...)
  status: KeyStatus (AVAILABLE | OUT | LOST)
  // Relations: issueRecords[]
}

Borrower {
  email: string (can be @placeholder.com)
  // Relations: issueRecords[]
}

IssueRecord {
  issuedDate: DateTime
  dueDate?: DateTime
  returnedDate?: DateTime (null = active loan)
  idChecked: boolean
}
```

### Standard User Lookup Pattern

```typescript
// ✅ ALWAYS use this pattern in server actions
async function getCurrentUserId() {
  const supabase = await createClient();
  const {
    data: { user },
  } = await supabase.auth.getUser();
  if (!user?.email) throw new Error('Not authenticated');

  const userRecord = await prisma.user.findUnique({
    where: { email: user.email }, // Lookup by email, NOT auth.id
    select: { id: true },
  });
  if (!userRecord) throw new Error('User not found');
  return userRecord.id;
}
```

### Database Access Rules

```typescript
// ✅ ALWAYS use Prisma for data operations
import { prisma } from '@/lib/prisma';

// ❌ NEVER use Supabase for data queries
// const { data } = await supabase.from('User')... // FORBIDDEN

// ✅ Standard query patterns
const keyTypes = await prisma.keyType.findMany({
  where: { userId }, // Always filter by current user
  include: { keyCopies: true }, // Include relations as needed
});

// ✅ Transaction pattern for complex operations
const result = await prisma.$transaction(async (tx) => {
  const keyType = await tx.keyType.create({ data: keyTypeData });

  if (totalCopies > 0) {
    const copies = Array.from({ length: totalCopies }, (_, i) => ({
      keyTypeId: keyType.id,
      copyNumber: i + 1,
      status: 'AVAILABLE' as const,
    }));
    await tx.keyCopy.createMany({ data: copies });
  }

  return keyType;
});
```

## 🔄 Server Action Patterns

### Standard Server Action Structure

```typescript
'use server';

import { prisma } from '@/lib/prisma';
import { createClient } from '@/lib/supabase/server';
import { revalidatePath } from 'next/cache';

type ActionResult<T> = { success: true; data?: T } | { success: false; error: string };

export async function createKeyType(formData: FormData): Promise<ActionResult<{ id: string }>> {
  try {
    // 1. Get current user (standard pattern)
    const userId = await getCurrentUserId();

    // 2. Extract and validate inputs
    const name = (formData.get('name') as string)?.trim();
    if (!name || name.length < 2) {
      return { success: false, error: 'Name must be at least 2 characters.' };
    }

    // 3. Database operations (use transactions for multiple operations)
    const result = await prisma.$transaction(async (tx) => {
      const keyType = await tx.keyType.create({
        data: { label, function: name, userId },
      });
      // Additional operations...
      return keyType;
    });

    // 4. Revalidate affected routes
    revalidatePath('/dashboard');
    return { success: true, data: { id: result.id } };
  } catch (error) {
    return { success: false, error: 'Failed to create key type' };
  }
}
```

### Form Handling Pattern

```typescript
// Client component
'use client';

import { useFormState } from 'react-dom';
import { createKeyType } from '@/app/actions/keyTypes';

export default function KeyTypeForm() {
  const [state, formAction] = useFormState(createKeyType, { success: false, error: '' });

  return (
    <form action={formAction} className="space-y-4">
      <Input name="name" placeholder="Key name..." required />
      {state.error && (
        <p className="text-sm text-destructive">{state.error}</p>
      )}
      <Button type="submit">Create Key Type</Button>
    </form>
  );
}
```

