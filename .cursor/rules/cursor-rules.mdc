## 📊 Database Pattern (Standard)

```typescript
// Standard user lookup pattern
async function getCurrentUserId() {
  const supabase = await createClient();
  const {
    data: { user },
  } = await supabase.auth.getUser();
  if (!user?.email) throw new Error('Not authenticated');

  const userRecord = await prisma.user.findUnique({
    where: { email: user.email }, // ALWAYS lookup by email
    select: { id: true },
  });
  if (!userRecord) throw new Error('User not found');
  return userRecord.id;
}

// ✅ ALWAYS use Prisma for data (never Supabase .from())
const data = await prisma.keyType.findMany({
  where: { userId }, // Always filter by user
});
```

## 🔄 Server Action Pattern (Essential)

```typescript
'use server';
import { prisma } from '@/lib/prisma';
import { createClient } from '@/lib/supabase/server';
import { revalidatePath } from 'next/cache';

type ActionResult<T> = { success: true; data?: T } | { success: false; error: string };

export async function serverAction(formData: FormData): Promise<ActionResult<any>> {
  try {
    // 1. Get current user ID
    const userId = await getCurrentUserId();

    // 2. Validate inputs
    const input = formData.get('input') as string;
    if (!input) return { success: false, error: 'Input required' };

    // 3. Database operation with transaction if needed
    const result = await prisma.$transaction(async (tx) => {
      return await tx.model.create({ data: { input, userId } });
    });

    // 4. Revalidate affected pages
    revalidatePath('/dashboard');
    return { success: true, data: result };
  } catch (error) {
    return { success: false, error: 'Operation failed' };
  }
}
```

## 🎨 Component Pattern (Essential)

```typescript
'use client';
import { useFormState } from 'react-dom';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { IconPlus } from '@tabler/icons-react';

export default function MyComponent() {
  const [state, formAction] = useFormState(serverAction, { success: false, error: '' });

  return (
    <Card>
      <CardHeader>
        <CardTitle>Component Title</CardTitle>
      </CardHeader>
      <CardContent>
        <form action={formAction} className="space-y-4">
          <Input name="input" required />
          {state.error && <p className="text-destructive text-sm">{state.error}</p>}
          <Button type="submit" className="gap-1">
            <IconPlus className="h-3.5 w-3.5" />
            Submit
          </Button>
        </form>
      </CardContent>
    </Card>
  );
}
```

