## Unique to This Project

### 1. Multi-Organisation Data Access Pattern

```typescript
// ✅ STANDARD: Use in ALL server actions & routes with organisation context
import { getCurrentUser } from '@/lib/auth-utils';

const user = await getCurrentUser(); 
// Returns: { id, email, entityId, roleInActiveOrg, allOrganisations[] }
// ⚠️ THROWS if user has no organisations

// All queries filtered by entityId (active organisation)
const data = await prisma.keyType.findMany({
  where: { entityId: user.entityId }, // Organisation-level isolation
});

// ⚠️ EXCEPTION: Use getCurrentUserOrNull() for edge cases
import { getCurrentUserOrNull } from '@/lib/auth-utils';

const user = await getCurrentUserOrNull();
// Returns: { id, email, activeOrganisationId, organisations[] } or null
// NEVER throws - returns null if not authenticated or no orgs:
//   - /no-organization
//   - /onboarding/keys
//   - /create-organization
```

### 2. Supabase for Auth, Prisma for Data

```typescript
// ✅ This is the ONLY valid Supabase usage
const supabase = await createClient();
const { data: { user } } = await supabase.auth.getUser();

// Then immediately switch to Prisma
const userRecord = await prisma.user.findUnique({
  where: { email: user.email }
});

// ❌ NEVER do this
const { data } = await supabase.from('User')... // FORBIDDEN
```

### 3. Placeholder Email System (Unique Feature)

```typescript
// For paper-based system transitions
function isPlaceholderEmail(email: string): boolean {
  return email.endsWith('@placeholder.com');
}

// Auto-generate from name
function generatePlaceholderEmail(name: string): string {
  return `${name
    .toLowerCase()
    .replace(/\s+/g, '.')
    .replace(/å/g, 'a')
    .replace(/ä/g, 'a')
    .replace(/ö/g, 'o')}@placeholder.com`;
}
```

### 4. ResponsiveDialog for User-Facing Dialogs

```typescript
// ✅ Use ResponsiveDialog for all user-facing dialogs
import { ResponsiveDialog } from '@/components/ui/responsive-dialog';

// Automatically renders Dialog on desktop, Drawer on mobile (< 768px)
// Built-in pointer-events cleanup prevents body from staying locked
<ResponsiveDialog
  open={isOpen}
  onOpenChange={setIsOpen}
  title="Dialog Title"
  description="Optional description"
  trigger={<Button>Open Dialog</Button>}  // Optional
  footer={<Button>Save</Button>}          // Optional
>
  <div>Dialog content</div>
</ResponsiveDialog>

// ❌ Don't use Dialog directly for user-facing dialogs
import { Dialog } from '@/components/ui/dialog'; // Only for UI primitives
```

