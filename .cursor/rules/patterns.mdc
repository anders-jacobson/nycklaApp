## Unique to This Project

### 1. Multi-Tenant Data Access with Entity Model

```typescript
// Always get entityId from user
async function getCurrentUser() {
  const supabase = await createClient();
  const {
    data: { user },
  } = await supabase.auth.getUser();
  if (!user?.email) throw new Error('Not authenticated');

  const userRecord = await prisma.user.findUnique({
    where: { email: user.email },
    select: { id: true, entityId: true, role: true },
  });
  if (!userRecord) throw new Error('User not found');
  return userRecord; // Returns { id, entityId, role }
}

// All queries filtered by entityId (not userId)
const data = await prisma.keyType.findMany({
  where: { entityId: user.entityId }, // Entity-level isolation
});
```

### 2. Supabase for Auth, Prisma for Data

```typescript
// ✅ This is the ONLY valid Supabase usage
const supabase = await createClient();
const { data: { user } } = await supabase.auth.getUser();

// Then immediately switch to Prisma
const userRecord = await prisma.user.findUnique({
  where: { email: user.email }
});

// ❌ NEVER do this
const { data } = await supabase.from('User')... // FORBIDDEN
```

### 3. Placeholder Email System (Unique Feature)

```typescript
// For paper-based system transitions
function isPlaceholderEmail(email: string): boolean {
  return email.endsWith('@placeholder.com');
}

// Auto-generate from name
function generatePlaceholderEmail(name: string): string {
  return `${name
    .toLowerCase()
    .replace(/\s+/g, '.')
    .replace(/å/g, 'a')
    .replace(/ä/g, 'a')
    .replace(/ö/g, 'o')}@placeholder.com`;
}
```

